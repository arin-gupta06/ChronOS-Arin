# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Connection
# For Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://127.0.0.1:27017/mits_Synapze

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Password Reset Configuration
RESET_TOKEN_SECRET=your_reset_secret_key
RESET_TOKEN_EXPIRE=15m

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@synapze.dev

# AI Configuration (Groq)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama_3_1
AI_PROVIDER=groq

# Optional DNS override for SRV lookups (useful for some ISP/Network issues)
DNS_SERVERS=8.8.8.8,1.1.1.1

# Features
RESTRICT_EMAIL_DOMAIN=false
ENABLE_DUMMY_ADMIN=false
